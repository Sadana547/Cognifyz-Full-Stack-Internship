<!DOCTYPE html>
<html>

<head>
    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <title>My Blog</title>

    <style>
    body {
        font-family: 'Segoe UI', sans-serif;
        background: linear-gradient(to right, #eef2f3, #dfe9f3);
    }

    /* Navbar */
    .navbar-brand {
        font-weight: bold;
        font-size: 24px;
        color: #4a00e0 !important;
    }

    /* Hero Section */
    .hero {
        height: 300px;
        padding: 40px;
        text-align: center;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(rgba(74,0,224,0.7), rgba(142,45,226,0.7)),
                    url('https://images.unsplash.com/photo-1515378791036-0648a3ef77b2');
        background-size: cover;
        background-position: center;
        border-radius: 0 0 30px 30px;
    }

    /* Blog Cards */
    .blog-card {
        transition: all 0.3s ease;
        border-radius: 16px;
        border: none;
        padding: 10px;
        animation: fadeIn 0.6s ease forwards;
    }

    .blog-card:hover {
        transform: translateY(-8px) scale(1.01);
        box-shadow: 0px 20px 50px rgba(142,45,226,0.3);
    }

    /* Text Styling */
    .card-title {
        font-size: 22px;
    }

    .card-text {
        font-size: 16px;
        line-height: 1.6;
    }

    /* Buttons */
    .btn {
        transition: all 0.3s ease;
    }

    .btn:hover {
        transform: scale(1.05);
    }

    .btn-primary {
        background: linear-gradient(45deg, #4a00e0, #8e2de2);
        border: none;
    }

    .btn-danger {
        border-radius: 20px;
    }

    /* Animation */
    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    </style>
</head>

<body>

    <!-- Navbar -->
    <nav class="navbar navbar-light bg-white shadow-sm">
        <div class="container">
            <span class="navbar-brand">✨ Sadana Blogs</span>
            <a href="/create" class="btn btn-primary">+ Create</a>
        </div>
    </nav>
<div class="container mt-4">
    <div class="card border-0 shadow-sm" style="background: rgba(74, 0, 224, 0.05); border-radius: 15px;">
        <div class="card-body py-3 d-flex align-items-center">
            <span class="badge bg-primary me-3">Daily Thought</span>
            <span id="api-quote" class="text-muted italic">Gathering inspiration...</span>
        </div>
    </div>
</div>

<script>
    // Task 5: Function to fetch data from an external API
    async function getInspiration() {
        try {
            // We call a real public API
            const response = await fetch('https://api.freeapi.app/api/v1/public/quotes/quote/random');
            const result = await response.json();
            
            // Extract the quote and author from the JSON response
            const quote = result.data.content || "Your story is worth telling.";
            const author = result.data.author || "Success";
            
            document.getElementById('api-quote').textContent = `"${quote}" — ${author}`;
        } catch (error) {
            // Fallback if the internet is slow
            document.getElementById('api-quote').textContent = "Consistency is the key to mastery. ✨";
        }
    }

    // Call the function immediately when the page loads
    getInspiration();
</script>

    <!-- Hero Section -->
    <div class="hero">
        <div>
            <h1 class="display-4 fw-bold">Where Words Feel Like Home ✨</h1>
            <p class="lead">Express your thoughts. Share your stories.</p>
            <a href="/create" class="btn btn-light mt-3 px-4">Start Writing</a>
        </div>
    </div>

    <!-- Blog Container -->
    <div class="container mt-5">

        <% blogs.forEach((blog, index) => { %>

            <div class="card mb-4 shadow blog-card">
                <div class="card-body">
                    <h4 class="card-title fw-bold"><%= blog.title %></h4>
                    <p class="card-text text-muted"><%= blog.content %></p>

                    <form action="/delete/<%= index %>" method="POST">
                        <button class="btn btn-danger btn-sm mt-2">Delete</button>
                    </form>
                </div>
            </div>

        <% }) %>

    </div>

</body>

</html>